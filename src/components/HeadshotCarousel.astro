---
// Headshot Carousel Component - Fades between all available headshots every 3 seconds
interface Props {
  altText?: string;
}

const { altText = "Deanna Stennett - Licensed Acupuncturist" } = Astro.props;

// List of all headshot filenames (10 total)
const headshots = [
  '/headshots/AA-headshot-1.jpeg',
  '/headshots/AA-headshot-2.jpeg',
  '/headshots/AA-headshot-3.jpeg',
  '/headshots/AA-headshot-4.jpeg',
  '/headshots/AA-headshot-5.jpeg',
  '/headshots/AA-headshot-6.jpeg',
  '/headshots/AA-headshot-7.jpeg',
  '/headshots/AA-headshot-8.jpeg',
  '/headshots/AA-headshot-9.jpeg',
  '/headshots/AA-headshot-10.jpg'
];
---

<div class="headshot-carousel">
  {headshots.map((src, index) => (
    <img 
      src={src} 
      alt={`${altText} - Photo ${index + 1}`}
      class="headshot-image"
      data-index={index}
    />
  ))}
</div>

<script>
  import { initHeadshotCarousel } from '../lib/headshotCarousel.js';
  
  // Initialize the carousel when component mounts
  if (typeof window !== 'undefined') {
    initHeadshotCarousel();
  }
</script>

<style is:global>
/* Headshot Carousel - Rounded Frame Styling */

.headshot-carousel {
  position: relative;
  width: 300px; /* Fixed container size for consistency */
  height: auto;
  margin: var(--spacing-lg) auto;
}

.headshot-image {
  display: block !important;
  max-width: 100% !important;
  width: 300px !important; /* Ensure consistent display size */
  height: auto !important;
  aspect-ratio: 2 / 3; /* Portrait orientation ratio for headshots */
  
  border-radius: var(--radius-lg); /* Rounded corners - nice frame effect */
  box-shadow: 
    0 4px 15px rgba(74, 124, 89, 0.2), /* Green-tinted shadow matching brand color */
    inset 0 0 30px rgba(255, 255, 255, 0.3); /* Inner glow for depth */
  
  opacity: 1;
  transition:
    opacity 1s ease-in-out,
    transform 400ms ease-out;
  
  object-fit: cover; /* Ensures images fill the frame consistently regardless of source dimensions */
}

.headshot-image:not(.active) {
  position: absolute !important;
  visibility: hidden;
  opacity: 0;
  pointer-events: none;
}

.headshot-image.active {
  z-index: 2;
}

/* Subtle hover effect for desktop users */
@media (hover: hover) and (min-width: 769px) {
  .headshot-carousel:hover .headshot-image:not(.active) {
    transform: scale(0.98); /* Slight dimming of non-active images */
  }
}

/* Mobile optimization - ensure touch-friendly sizing */
@media (max-width: 768px) {
  .headshot-carousel {
    width: 280px; /* Larger on mobile for better visibility */
    margin: var(--spacing-lg);
  }
  
  .headshot-image {
    max-width: 100% !important;
    width: 280px !important;
  }
}

/* Accessibility - focus states not needed (images are decorative) but ensure keyboard users can skip past if needed */
.headshot-carousel:focus-within {
  outline: none;
}
</style>
