---
import Layout from '../layouts/Layout.astro';
import ContactSection from '../components/ContactSection.astro';
import MobileCTA from '../components/MobileCTA.astro';
import * as config from '../config/contact.ts';

const pageData = {
  title: `Acupuncture in Blairsville GA | Holistic Medicine Near Me`,
  description: `Expert acupuncture services in Blairsville, Georgia. ${config.PRACTICE.founderName} provides Traditional Chinese Medicine, Five-Element Acupuncture, and NAET allergy treatment right here in Union County.
`,
  keywords: [
    'acupuncture Blairsville GA',
    'acupuncture near me Blairsville',
    'holistic medicine Blairsville',
    'alternative medicine Blairsville Georgia',
    'Five-Element Acupuncture Blairsville'
  ],
  canonicalUrl: `${config.DOMAIN}/blairsville-ga`
};

const serviceArea = {
  name: 'Blairsville',
  distance: 'Located in downtown Blairsville',
  landmarks: ['Union County Courthouse', 'Folk Art Center of Georgia', 'Black Rock Mountain State Park'],
  nearbyTowns: ['Hiawassee', 'Young Harris', 'Tallulah Falls', 'Ellijay']
};

const localContent = `Patients in Blairsville and surrounding Union County trust Deanna Stennett for expert acupuncture care. Whether you search "acupuncture near me" or "holistic medicine Blairsville," we're here to help you achieve optimal health right here in your community.`;
---

<Layout 
  title={pageData.title} 
  description={pageData.description} 
  keywords={pageData.keywords}
  canonicalUrl={pageData.canonicalUrl}
>
  <!-- Hero Section -->
  <section class="hero">
    <div class="container hero-content">
      <h1>Acupuncture in Blairsville, Georgia</h1>
      <p style="font-size: 1.25rem; opacity: 0.95;">Expert Holistic Medicine Right Here in Union County</p>
      
      <div class="margin-top-lg">
        <a href="#contact" class="btn btn-primary hero-btn margin-right-sm">Book Appointment</a>
        <a href={config.getPhoneLink()} class="btn btn-secondary hero-btn-alt">{config.PHONE.formatted}</a>
      </div>
    </div>
  </section>

  <!-- Logo at top (no headshot on this page) -->
  <section class="section section-light">
    <div class="container text-center margin-bottom-xl">
      <img src="/logo-large.svg" alt="Acupuncture in North Georgia - Deanna Stennett" class="logo-img" />
    </div>
  </section>

  <!-- Local SEO Content -->
  <section class="section section-light">
    <div class="container">
      <h2 style="margin-bottom: var(--spacing-lg);">Acupuncture Near Me in Blairsville</h2>
      
      <p style="font-size: 1.125rem; line-height: 1.8;">Living in the beautiful mountains of Union County, Blairsville deserves access to expert holistic healthcare. Deanna Stennett provides comprehensive acupuncture services right here in downtown Blairsville, serving patients throughout the Blairsville area and surrounding communities.</p>
      
      <p style="font-size: 1.125rem; line-height: 1.8;">Whether you're searching for "acupuncture near me" or "holistic medicine Blairsville," our practice offers Traditional Chinese Medicine, Five-Element Acupuncture, NAET allergy treatment, and Facial Rejuvenation acupuncture—all designed to restore your body's natural healing balance.</p>

      <!-- Local Landmarks -->
      <div class="margin-top-xl">
        <h3>Serving Blairsville & Surrounding Areas</h3>
        
        <div class="card-grid margin-top-md">
          <article class="card text-center">
            <div style="font-size: 3rem; margin-bottom: var(--spacing-sm);">🏛️</div>
            <h4>{serviceArea.name}</h4>
            <p>Main office location - downtown Blairsville</p>
          </article>

          {serviceArea.nearbyTowns.map(town => (
            <article class="card text-center">
              <div style="font-size: 3rem; margin-bottom: var(--spacing-sm);">📍</div>
              <h4>{town}</h4>
              <p>Serving patients from this community</p>
            </article>
          ))}

          <article class="card text-center">
            <div style="font-size: 3rem; margin-bottom: var(--spacing-sm);">🌲</div>
            <h4>Union County</h4>
            <p>Serving throughout the region</p>
          </article>
        </div>
      </div>

      <!-- Conditions Treated Locally -->
      <div class="margin-top-xl">
        <h3>Common Concerns We Treat in Blairsville</h3>
        
        <ul class="list-none flex-wrap gap-sm padding-left-0">
          {['Back pain from hiking', 'Migraines and headaches', 'Stress and anxiety', 'Allergies (seasonal & environmental)', 'Sports injuries', 'Chronic fatigue', 'Sleep disorders'].map(condition => (
            <li class="card-item">✓ {condition}</li>
          ))}
        </ul>
      </div>

      <!-- Why Choose Us -->
      <div class="margin-top-xl bg-surface padding-lg border-radius-sm">
        <h3>Why Blairsville Patients Choose Deanna</h3>
        
        <ul class="list-none margin-top-sm">
          <li class="padding-xs">✓ 30+ years of clinical experience serving North Georgia</li>
          <li class="padding-xs">✓ NCCAOM certified and Georgia licensed acupuncturist</li>
          <li class="padding-xs">✓ Dual expertise in Five-Element & Traditional Chinese Medicine</li>
          <li class="padding-xs">✓ Convenient downtown Blairsville location</li>
          <li class="padding-xs">✓ Personalized treatment plans for each patient's unique needs</li>
        </ul>
      </div>

      <!-- Call-to-action -->
      <div class="margin-top-xl text-center">
        <h3>Ready to Start Your Healing Journey?</h3>
        <p style="font-size: 1.25rem; margin-bottom: var(--spacing-md);">Blairsville patients trust Deanna for expert acupuncture care.</p>
        
        <a href="#contact" class="btn btn-primary">Request an Appointment</a>
      </div>
    </div>
  </section>

  <!-- Logo at bottom (no headshot on this page) -->
  <section class="section section-light margin-top-xl">
    <div class="container text-center">
      <img src="/logo-large.svg" alt="Acupuncture in North Georgia - Deanna Stennett" class="logo-img" />
    </div>
  </section>

  <!-- Contact Section -->
  <ContactSection />

  <!-- Mobile Sticky CTA -->
  <MobileCTA />

  <!-- SEO Content Block -->
  <article style="display: none;">
    <h2>Acupuncture in Blairsville GA - Holistic Medicine Near Me</h2>
    <p>Deanna Stennett provides expert acupuncture services to patients throughout Blairsville, Georgia and the surrounding Union County mountains. Our downtown Blairsville office offers Traditional Chinese Medicine, Five-Element Acupuncture, NAET allergy treatment, and Facial Rejuvenation.</p>

    <h3>Acupuncture Near Me - Blairsville GA</h3>
    <p>Searching "acupuncture near me" in Blairsville? Our convenient location serves patients from Blairsville, Hiawassee, Young Harris, Tallulah Falls, Ellijay, and throughout Union County. Whether you're dealing with back pain from hiking Black Rock Mountain, seasonal allergies, or chronic health concerns, Deanna provides personalized acupuncture treatment.</p>

    <h3>Holistic Medicine in Blairsville</h3>
    <p>As a licensed acupuncturist with 30+ years of experience, Deanna bridges holistic and Western medicine to provide comprehensive care. Patients trust us for treating migraines, stress and anxiety, sports injuries, sleep disorders, digestive issues, and more.</p>

    <h3>Serving Union County</h3>
    <p>Besides Blairsville, we serve patients from Dahlonega, Jasper, Helen, Blue Ridge, Brasstown, and throughout the region. Search "acupuncture near me" to find your holistic healing center in Northern Georgia.</p>

    <h3>Five-Element Acupuncture in Blairsville</h3>
    <p>Deanna studied with Professor J.R. Worsley, a pioneer in bringing Five-Element Acupuncture to Western culture. This holistic approach addresses root emotional and physical causes of illness through elemental theory.</p>

    <h3>NAET Allergy Treatment Near Blairsville</h3>
    <p>Safe, non-invasive NAET treatment helps eliminate allergies to foods, environmental triggers, and chemicals. Many Union County patients have achieved remarkable results with NAET for seasonal allergies and food intolerances.</p>
  </article>
</Layout>
