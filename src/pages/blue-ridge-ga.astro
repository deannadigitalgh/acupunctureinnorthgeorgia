---
import Layout from '../layouts/Layout.astro';
import ContactSection from '../components/ContactSection.astro';
import MobileCTA from '../components/MobileCTA.astro';
import * as config from '../config/contact.ts';

const pageData = {
  title: `Acupuncture in Blue Ridge GA | Holistic Medicine Near Me`,
  description: `Expert acupuncture services in Blue Ridge, Georgia. ${config.PRACTICE.founderName} provides Traditional Chinese Medicine, Five-Element Acupuncture, and NAET allergy treatment just minutes from Blue Ridge.`,
  keywords: [
    'acupuncture Blue Ridge GA',
    'acupuncture near me Blue Ridge',
    'holistic medicine Blue Ridge',
    'alternative medicine Blue Ridge Georgia',
    'Five-Element Acupuncture Blue Ridge'
  ],
  canonicalUrl: `${config.DOMAIN}/blue-ridge-ga`
};

const serviceArea = {
  name: 'Blue Ridge',
  distance: '15 minutes from Ellijay office',
  landmarks: ['Brasstown Bald', 'Blue Ridge Mountain Scenic Railway', 'Lake Blue Ridge'],
  nearbyTowns: ['Morganton', 'Young Harris', 'Hiawassee']
};

const localContent = `Patients in Blue Ridge and surrounding North Georgia mountains trust Deanna Stennett for expert acupuncture care. Whether you search "acupuncture near me" or "holistic medicine Blue Ridge," we're here to help you achieve optimal health.`;
---

<Layout 
  title={pageData.title} 
  description={pageData.description} 
  keywords={pageData.keywords}
  canonicalUrl={pageData.canonicalUrl}
>
  <!-- Hero Section -->
  <section class="hero">
    <div class="container hero-content">
      <h1>Acupuncture in Blue Ridge, Georgia</h1>
      <p style="font-size: 1.25rem; opacity: 0.95;">Expert Holistic Medicine Just 15 Minutes Away</p>
      
      <div style="margin-top: var(--spacing-lg);">
        <a href="#contact" class="btn btn-primary" style="background-color: white; color: var(--color-primary); margin-right: var(--spacing-sm);">Book Appointment</a>
        <a href={config.getPhoneLink()} class="btn btn-secondary" style="border-color: white; color: white;">{config.PHONE.formatted}</a>
      </div>
    </div>
  </section>

  <!-- Logo at top (no headshot on this page) -->
  <section class="section section-light">
    <div class="container" style="text-align: center; margin-bottom: var(--spacing-xl);">
      <img src="/logo-large.svg" alt="Acupuncture in North Georgia - Deanna Stennett" style="max-width: 300px; width: 100%; height: auto;" />
    </div>
  </section>

  <!-- Local SEO Content -->
  <section class="section section-light">
    <div class="container">
      <h2 style="margin-bottom: var(--spacing-lg);">Acupuncture Near Me in Blue Ridge</h2>
      
      <p style="font-size: 1.125rem; line-height: 1.8;">Living in the beautiful North Georgia mountains of Blue Ridge, you deserve access to expert holistic healthcare. Deanna Stennett provides comprehensive acupuncture services just 15 minutes from downtown Blue Ridge, serving patients throughout the Blue Ridge area and surrounding communities.</p>
      
      <p style="font-size: 1.125rem; line-height: 1.8;">Whether you're searching for "acupuncture near me" or "holistic medicine Blue Ridge," our practice offers Traditional Chinese Medicine, Five-Element Acupuncture, NAET allergy treatment, and Facial Rejuvenation acupuncture—all designed to restore your body's natural healing balance.</p>

      <!-- Local Landmarks -->
      <div style="margin-top: var(--spacing-xl);">
        <h3>Serving Blue Ridge & Surrounding Areas</h3>
        
        <div class="card-grid" style="grid-template-columns: repeat(auto-fit, minmax(250px, 1fr)); margin-top: var(--spacing-md);">
          <article class="card" style="text-align: center;">
            <div style="font-size: 3rem; margin-bottom: var(--spacing-sm);">🏔️</div>
            <h4>{serviceArea.name}</h4>
            <p>Main service area - 15 minutes away</p>
          </article>

          {serviceArea.nearbyTowns.map(town => (
            <article class="card" style="text-align: center;">
              <div style="font-size: 3rem; margin-bottom: var(--spacing-sm);">📍</div>
              <h4>{town}</h4>
              <p>Serving patients from this community</p>
            </article>
          ))}

          <article class="card" style="text-align: center;">
            <div style="font-size: 3rem; margin-bottom: var(--spacing-sm);">🌲</div>
            <h4>North Georgia Mountains</h4>
            <p>Serving throughout the region</p>
          </article>
        </div>
      </div>

      <!-- Conditions Treated Locally -->
      <div style="margin-top: var(--spacing-xl);">
        <h3>Common Concerns We Treat in Blue Ridge</h3>
        
        <ul style="list-style-type: none; display: flex; flex-wrap: wrap; gap: var(--spacing-sm); padding-left: 0;">
          {['Back pain from hiking', 'Migraines and headaches', 'Stress and anxiety', 'Allergies (seasonal & environmental)', 'Sports injuries', 'Chronic fatigue', 'Sleep disorders'].map(condition => (
            <li style="background-color: var(--color-surface); padding: var(--spacing-sm) var(--spacing-lg); border-radius: var(--radius-md); box-shadow: var(--shadow-sm);">✓ {condition}</li>
          ))}
        </ul>
      </div>

      <!-- Why Choose Us -->
      <div style="margin-top: var(--spacing-xl); background-color: var(--color-background); padding: var(--spacing-lg); border-radius: var(--radius-md);">
        <h3>Why Blue Ridge Patients Choose Deanna</h3>
        
        <ul style="list-style-type: none; margin-top: var(--spacing-sm);">
          <li style="padding: var(--spacing-xs) 0;">✓ 30+ years of clinical experience serving North Georgia</li>
          <li style="padding: var(--spacing-xs) 0;">✓ NCCAOM certified and Georgia licensed acupuncturist</li>
          <li style="padding: var(--spacing-xs) 0;">✓ Dual expertise in Five-Element & Traditional Chinese Medicine</li>
          <li style="padding: var(--spacing-xs) 0;">✓ Convenient location just 15 minutes from Blue Ridge</li>
          <li style="padding: var(--spacing-xs) 0;">✓ Personalized treatment plans for each patient's unique needs</li>
        </ul>
      </div>

      <!-- Call-to-action -->
      <div style="margin-top: var(--spacing-xl); text-align: center;">
        <h3>Ready to Start Your Healing Journey?</h3>
        <p style="font-size: 1.25rem; margin-bottom: var(--spacing-md);">Blue Ridge patients trust Deanna for expert acupuncture care.</p>
        
        <a href="#contact" class="btn btn-primary">Request an Appointment</a>
      </div>
    </div>
  </section>

  <!-- Logo at bottom (no headshot on this page) -->
  <section class="section section-light" style="margin-top: var(--spacing-xl);">
    <div class="container" style="text-align: center;">
      <img src="/logo-large.svg" alt="Acupuncture in North Georgia - Deanna Stennett" style="max-width: 300px; width: 100%; height: auto;" />
    </div>
  </section>

  <!-- Contact Section -->
  <ContactSection />

  <!-- Mobile Sticky CTA -->
  <MobileCTA />

  <!-- SEO Content Block -->
  <article style="display: none;">
    <h2>Acupuncture in Blue Ridge GA - Holistic Medicine Near Me</h2>
    <p>Deanna Stennett provides expert acupuncture services to patients throughout Blue Ridge, Georgia and the surrounding North Georgia mountains. Just 15 minutes from downtown Blue Ridge, our practice offers Traditional Chinese Medicine, Five-Element Acupuncture, NAET allergy treatment, and Facial Rejuvenation.</p>

    <h3>Acupuncture Near Me - Blue Ridge GA</h3>
    <p>Searching "acupuncture near me" in Blue Ridge? Our convenient location serves patients from Blue Ridge, Morganton, Young Harris, Hiawassee, and throughout the North Georgia mountains. Whether you're dealing with back pain from hiking Brasstown Bald, seasonal allergies, or chronic health concerns, Deanna provides personalized acupuncture treatment.</p>

    <h3>Holistic Medicine in Blue Ridge</h3>
    <p>As a licensed acupuncturist with 30+ years of experience, Deanna bridges holistic and Western medicine to provide comprehensive care. Patients trust us for treating migraines, stress and anxiety, sports injuries, sleep disorders, digestive issues, and more.</p>

    <h3>Serving North Georgia Mountains</h3>
    <p>Besides Blue Ridge, we serve patients from Dahlonega, Jasper, Helen, Tallulah Falls, Ellijay, Blairsville, and throughout the region. Search "acupuncture near me" to find your holistic healing center in Northern Georgia.</p>

    <h3>Five-Element Acupuncture in Blue Ridge</h3>
    <p>Deanna studied with Professor J.R. Worsley, a pioneer in bringing Five-Element Acupuncture to Western culture. This holistic approach addresses root emotional and physical causes of illness through elemental theory.</p>

    <h3>NAET Allergy Treatment Near Blue Ridge</h3>
    <p>Safe, non-invasive NAET treatment helps eliminate allergies to foods, environmental triggers, and chemicals. Many North Georgia patients have achieved remarkable results with NAET for seasonal allergies and food intolerances.</p>
  </article>
</Layout>
