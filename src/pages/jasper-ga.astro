---
import Layout from '../layouts/Layout.astro';
import * as config from '../config/contact.ts';

const pageData = {
  title: `Acupuncture in Jasper GA | Holistic Medicine Near Me`,
  description: `Expert acupuncture services in Jasper, Georgia. ${config.PRACTICE.founderName} provides Traditional Chinese Medicine and Five-Element Acupuncture just 25 minutes from Jasper.`,
  keywords: [
    'acupuncture Jasper GA',
    'acupuncture near me Jasper',
    'holistic medicine Jasper',
    'alternative medicine Jasper Georgia'
  ],
  canonicalUrl: `${config.DOMAIN}/jasper-ga`
};

const serviceArea = {
  name: 'Jasper',
  distance: '25 minutes from Ellijay office',
  landmarks: ['Lake Allatoona', 'Amicalola Falls State Park', 'Jasper Square'],
  nearbyTowns: ['Helen GA', 'Dawsonville GA', 'Braswell GA']
};

const localContent = `Patients in Jasper and surrounding North Georgia trust Deanna Stennett for expert acupuncture care. Whether you search "acupuncture near me" or "holistic medicine Jasper," we're here to help.`;
---

<Layout 
  title={pageData.title} 
  description={pageData.description} 
  keywords={pageData.keywords}
  canonicalUrl={pageData.canonicalUrl}
>
  <!-- Hero Section -->
  <section class="hero">
    <div class="container hero-content">
      <h1>Acupuncture in Jasper, Georgia</h1>
      <p style="font-size: 1.25rem; opacity: 0.95;">Expert Holistic Medicine Just 25 Minutes Away</p>
      
      <div style="margin-top: var(--spacing-lg);">
        <a href="#contact" class="btn btn-primary" style="background-color: white; color: var(--color-primary); margin-right: var(--spacing-sm);">Book Appointment</a>
        <a href={config.getPhoneLink()} class="btn btn-secondary" style="border-color: white; color: white;">{config.PHONE.formatted}</a>
      </div>
    </div>
  </section>

  <!-- Logo at top (no headshot on this page) -->
  <section class="section section-light">
    <div class="container" style="text-align: center; margin-bottom: var(--spacing-xl);">
      <img src="/logo-large.svg" alt="Acupuncture in North Georgia - Deanna Stennett" style="max-width: 300px; width: 100%; height: auto;" />
    </div>
  </section>

  <!-- Local SEO Content -->
  <section class="section section-light">
    <div class="container">
      <h2 style="margin-bottom: var(--spacing-lg);">Acupuncture Near Me in Jasper</h2>
      
      <p style="font-size: 1.125rem; line-height: 1.8;">Living in the beautiful North Georgia mountains of Jasper, you deserve access to expert holistic healthcare. Deanna Stennett provides comprehensive acupuncture services just 25 minutes from downtown Jasper, serving patients throughout the Jasper area and surrounding communities.</p>
      
      <p style="font-size: 1.125rem; line-height: 1.8;">Whether you're searching for "acupuncture near me" or "holistic medicine Jasper," our practice offers Traditional Chinese Medicine, Five-Element Acupuncture, NAET allergy treatment, and Facial Rejuvenation acupuncture—all designed to restore your body's natural healing balance.</p>

      <!-- Local Landmarks -->
      <div style="margin-top: var(--spacing-xl);">
        <h3>Serving Jasper & Surrounding Areas</h3>
        
        <div class="card-grid" style="grid-template-columns: repeat(auto-fit, minmax(250px, 1fr)); margin-top: var(--spacing-md);">
          <article class="card" style="text-align: center;">
            <div style="font-size: 3rem; margin-bottom: var(--spacing-sm);">🏔️</div>
            <h4>{serviceArea.name}</h4>
            <p>Main service area - 25 minutes away</p>
          </article>

          {serviceArea.nearbyTowns.map(town => (
            <article class="card" style="text-align: center;">
              <div style="font-size: 3rem; margin-bottom: var(--spacing-sm);">📍</div>
              <h4>{town}</h4>
              <p>Serving patients from this community</p>
            </article>
          ))}

          <article class="card" style="text-align: center;">
            <div style="font-size: 3rem; margin-bottom: var(--spacing-sm);">🌲</div>
            <h4>North Georgia Mountains</h4>
            <p>Serving throughout the region</p>
          </article>
        </div>
      </div>

      <!-- Conditions Treated Locally -->
      <div style="margin-top: var(--spacing-xl);">
        <h3>Common Concerns We Treat in Jasper</h3>
        
        <ul style="list-style-type: none; display: flex; flex-wrap: wrap; gap: var(--spacing-sm); padding-left: 0;">
          {['Back pain from hiking', 'Migraines and headaches', 'Stress and anxiety', 'Allergies (seasonal & environmental)', 'Sports injuries', 'Chronic fatigue', 'Sleep disorders'].map(condition => (
            <li style="background-color: var(--color-surface); padding: var(--spacing-sm) var(--spacing-lg); border-radius: var(--radius-md); box-shadow: var(--shadow-sm);">✓ {condition}</li>
          ))}
        </ul>
      </div>

      <!-- Why Choose Us -->
      <div style="margin-top: var(--spacing-xl); background-color: var(--color-background); padding: var(--spacing-lg); border-radius: var(--radius-md);">
        <h3>Why Jasper Patients Choose Deanna</h3>
        
        <ul style="list-style-type: none; margin-top: var(--spacing-sm);">
          <li style="padding: var(--spacing-xs) 0;">✓ 30+ years of clinical experience serving North Georgia</li>
          <li style="padding: var(--spacing-xs) 0;">✓ NCCAOM certified and Georgia licensed acupuncturist</li>
          <li style="padding: var(--spacing-xs) 0;">✓ Dual expertise in Five-Element & Traditional Chinese Medicine</li>
          <li style="padding: var(--spacing-xs) 0;">✓ Convenient location just 25 minutes from Jasper</li>
          <li style="padding: var(--spacing-xs) 0;">✓ Personalized treatment plans for each patient's unique needs</li>
        </ul>
      </div>

      <!-- Call-to-action -->
      <div style="margin-top: var(--spacing-xl); text-align: center;">
        <h3>Ready to Start Your Healing Journey?</h3>
        <p style="font-size: 1.25rem; margin-bottom: var(--spacing-md);">Jasper patients trust Deanna for expert acupuncture care.</p>
        
        <a href="#contact" class="btn btn-primary">Request an Appointment</a>
      </div>
    </div>
  </section>

  <!-- Logo at bottom (no headshot on this page) -->
  <section class="section section-light" style="margin-top: var(--spacing-xl);">
    <div class="container" style="text-align: center;">
      <img src="/logo-large.svg" alt="Acupuncture in North Georgia - Deanna Stennett" style="max-width: 300px; width: 100%; height: auto;" />
    </div>
  </section>

  <!-- Contact Section -->
  <section id="contact" class="section section-gray">
    <div class="container">
      <h2 style="text-align: center; margin-bottom: var(--spacing-lg);">Contact Us</h2>
      
      <div style="display: grid; gap: var(--spacing-xl); grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));">
        <!-- Contact Info -->
        <div>
          <h3>Office Locations</h3>
          
          <div style="margin-top: var(--spacing-md);">
            <h4>Ellijay Office (Primary)</h4>
            <address style="font-style: normal;">{config.OFFICES.ellijay.fullAddress}</address>
            <p><strong>Distance from Jasper:</strong> {serviceArea.distance}</p>
          </div>

          <div style="margin-top: var(--spacing-md);">
            <h4>Blairsville Office</h4>
            <address style="font-style: normal;">{config.OFFICES.blairsville.fullAddress}</address>
          </div>

          <div style="margin-top: var(--spacing-md);">
            <h4>Phone</h4>
            <a href={config.getPhoneLink()} style="font-size: 1.25rem; font-weight: 600;">{config.PHONE.formatted}</a>
          </div>

          <div style="margin-top: var(--spacing-md);">
            <h4>Hours</h4>
            <p>{config.HOURS.fullDescription}</p>
          </div>
        </div>

        <!-- Contact Form -->
        <form class="contact-form" action="/api/contact" method="POST">
          <h3 style="text-align: center; margin-bottom: var(--spacing-md);">Request an Appointment</h3>
          
          <div class="form-group">
            <label for="name" class="form-label">Full Name *</label>
            <input type="text" id="name" name="name" class="form-input" required placeholder="Your full name"/>
          </div>

          <div class="form-group">
            <label for="phone" class="form-label">Phone Number *</label>
            <input type="tel" id="phone" name="phone" class="form-input" required placeholder="(410) 961-9033"/>
          </div>

          <div class="form-group">
            <label for="email" class="form-label">Email Address *</label>
            <input type="email" id="email" name="email" class="form-input" required placeholder="your@email.com"/>
          </div>

          <button type="submit" class="btn btn-primary" style="width: 100%;">Request Appointment</button>
          
          <p style="font-size: 0.75rem; color: var(--color-text-secondary); margin-top: var(--spacing-xs); text-align: center;">
            Your information is kept confidential and HIPAA-compliant. 
            <a href="/privacy-policy">Privacy Policy</a>
          </p>
        </form>
      </div>
    </div>
  </section>

  <!-- SEO Content Block -->
  <article style="display: none;">
    <h2>Acupuncture in Jasper GA - Holistic Medicine Near Me</h2>
    <p>Deanna Stennett provides expert acupuncture services to patients throughout Jasper, Georgia and the surrounding North Georgia mountains. Just 25 minutes from downtown Jasper, our practice offers Traditional Chinese Medicine, Five-Element Acupuncture, NAET allergy treatment, and Facial Rejuvenation.</p>

    <h3>Acupuncture Near Me - Jasper GA</h3>
    <p>Searching "acupuncture near me" in Jasper? Our convenient location serves patients from Jasper, Helen GA, Dawsonville GA, Braswell GA, and throughout the North Georgia mountains. Whether you're dealing with back pain from hiking Amicalola Falls, seasonal allergies, or chronic health concerns, Deanna provides personalized acupuncture treatment.</p>

    <h3>Holistic Medicine in Jasper</h3>
    <p>As a licensed acupuncturist with 30+ years of experience, Deanna bridges holistic and Western medicine to provide comprehensive care. Patients trust us for treating migraines, stress and anxiety, sports injuries, sleep disorders, digestive issues, and more.</p>

    <h3>Serving North Georgia Mountains</h3>
    <p>Besides Jasper, we serve patients from Dahlonega, Helen, Tallulah Falls, Ellijay, Blairsville, Blue Ridge, and throughout the region. Search "acupuncture near me" to find your holistic healing center in Northern Georgia.</p>

    <h3>Five-Element Acupuncture in Jasper</h3>
    <p>Deanna studied with Professor J.R. Worsley, a pioneer in bringing Five-Element Acupuncture to Western culture. This holistic approach addresses root emotional and physical causes of illness through elemental theory.</p>

    <h3>NAET Allergy Treatment Near Jasper</h3>
    <p>Safe, non-invasive NAET treatment helps eliminate allergies to foods, environmental triggers, and chemicals. Many North Georgia patients have achieved remarkable results with NAET for seasonal allergies and food intolerances.</p>
  </article>
</Layout>
