---
import Layout from '../layouts/Layout.astro';
import ContactSection from '../components/ContactSection.astro';

const title = 'Privacy Policy';
const description = 'Privacy policy for Acupuncture in North Georgia - Deanna Stennett, Licensed Acupuncturist serving Ellijay, Blairsville, and Northern Georgia.';
const keywords = ['privacy policy', 'healthcare privacy', 'HIPAA', 'patient information', 'Acupuncture in North Georgia'];

// Note: This is a basic privacy policy template. Consult with a healthcare attorney to ensure HIPAA compliance.
---

<Layout title={title} description={description} keywords={keywords}>
  <main>
    <!-- Hero Section -->
    <section class="hero">
      <div class="container hero-content">
        <h1>Privacy Policy</h1>
        <p>Your privacy is important to us. This policy explains how we collect, use, and protect your personal information.</p>
      </div>
    </section>

    <!-- Privacy Content -->
    <section class="section section-light">
      <div class="container">
        <article style="max-width: 800px; margin: 0 auto;">
          <h2>Last Updated: February 2026</h2>
          
          <p>At Acupuncture in North Georgia, we are committed to protecting your privacy and maintaining the confidentiality of your personal health information. This Privacy Policy explains how we handle your data when you visit our website or receive treatment from us.</p>

          <hr style="border: none; border-top: 1px solid var(--color-border); margin: var(--spacing-lg) 0;" />

          <h3 id="information-collection">Information We Collect</h3>
          <p>We collect the following types of information:</p>
          <ul style="margin-left: var(--spacing-lg); margin-bottom: var(--spacing-md);">
            <li><strong>Contact Information:</strong> Name, phone number, email address (when you fill out our contact form)</li>
            <li><strong>Health Information:</strong> Medical history, current health conditions, treatment preferences (collected during consultations and maintained in confidential patient records)</li>
            <li><strong>Website Usage Data:</strong> IP address, browser type, pages visited (via Google Analytics if enabled)</li>
          </ul>

          <hr style="border: none; border-top: 1px solid var(--color-border); margin: var(--spacing-lg) 0;" />

          <h3 id="how-we-use-information">How We Use Your Information</h3>
          <p>We use your information for the following purposes:</p>
          <ul style="margin-left: var(--spacing-lg); margin-bottom: var(--spacing-md);">
            <li>To schedule and manage your appointments</li>
            <li>To provide acupuncture treatments and holistic health services</li>
            <li>To communicate with you about your care, including follow-up calls as requested through our contact form</li>
            <li>To send appointment reminders and important health updates (with your consent)</li>
            <li>To improve our website and services</li>
            <li>To comply with legal obligations and maintain required medical records</li>
          </ul>

          <hr style="border: none; border-top: 1px solid var(--color-border); margin: var(--spacing-lg) 0;" />

          <h3 id="hipaa-compliance">HIPAA Compliance</h3>
          <p>Acupuncture in North Georgia is committed to maintaining the confidentiality of your protected health information (PHI) in accordance with the Health Insurance Portability and Accountability Act (HIPAA). Your medical records are:</p>
          <ul style="margin-left: var(--spacing-lg); margin-bottom: var(--spacing-md);">
            <li>Stored in secure, password-protected systems</li>
            <li>Accessible only to authorized healthcare providers involved in your care</li>
            <li>Maintained for the period required by Georgia state law (minimum 7 years from date of service)</li>
            <li>Never shared with third parties without your written consent, except as required by law</li>
          </ul>

          <hr style="border: none; border-top: 1px solid var(--color-border); margin: var(--spacing-lg) 0;" />

          <h3 id="website-forms">Website Contact Form Security</h3>
          <p>When you submit information through our website contact form:</p>
          <ul style="margin-left: var(--spacing-lg); margin-bottom: var(--spacing-md);">
            <li>Your data is transmitted securely via HTTPS encryption</li>
            <li>Information is sent directly to our secure email system (via Formspree)</li>
            <li>We do not store your information in our website database</li>
            <li>The form does not collect sensitive health information - please call us to discuss medical details</li>
          </ul>

          <hr style="border: none; border-top: 1px solid var(--color-border); margin: var(--spacing-lg) 0;" />

          <h3 id="data-sharing">Information Sharing</h3>
          <p>We do not sell, trade, or rent your personal information to third parties. We may share your information only in the following circumstances:</p>
          <ul style="margin-left: var(--spacing-lg); margin-bottom: var(--spacing-md);">
            <li><strong>Healthcare Providers:</strong> With other healthcare professionals involved in your treatment</li>
            <li><strong>Legal Requirements:</strong> When required by law, court order, or government investigation</li>
            <li><strong>Emergency Situations:</strong> To protect the health and safety of you or others</li>
            <li><strong>Service Providers:</strong> With trusted vendors who help us operate our practice (e.g., email services, billing systems) under confidentiality agreements</li>
          </ul>

          <hr style="border: none; border-top: 1px solid var(--color-border); margin: var(--spacing-lg) 0;" />

          <h3 id="your-rights">Your Rights</h3>
          <p>You have the right to:</p>
          <ul style="margin-left: var(--spacing-lg); margin-bottom: var(--spacing-md);">
            <li>Access your medical records and receive a copy</li>
            <li>Request corrections to inaccurate information</li>
            <li>Request restrictions on how your information is used</li>
            <li>Receive an accounting of disclosures made about your information</li>
            <li>File a complaint with the U.S. Department of Health and Human Services if you believe your privacy rights have been violated</li>
          </ul>

          <hr style="border: none; border-top: 1px solid var(--color-border); margin: var(--spacing-lg) 0;" />

          <h3 id="cookies">Cookies and Website Tracking</h3>
          <p>Our website may use cookies and similar technologies to enhance your experience. Cookies are small files stored on your device that help us:</p>
          <ul style="margin-left: var(--spacing-lg); margin-bottom: var(--spacing-md);">
            <li>Remember your preferences</li>
            <li>Understand how you use our website</li>
            <li>Improve our services</li>
          </ul>
          <p>You can control cookies through your browser settings. Disabling cookies may affect certain features of our website.</p>

          <hr style="border: none; border-top: 1px solid var(--color-border); margin: var(--spacing-lg) 0;" />

          <h3 id="data-security">Data Security</h3>
          <p>We implement appropriate technical and organizational measures to protect your information, including:</p>
          <ul style="margin-left: var(--spacing-lg); margin-bottom: var(--spacing-md);">
            <li>SSL/TLS encryption for all data transmissions</li>
            <li>Password-protected systems with restricted access</li>
            <li>Regular security updates and monitoring</li>
            <li>Secure backup procedures</li>
          </ul>

          <hr style="border: none; border-top: 1px solid var(--color-border); margin: var(--spacing-lg) 0;" />

          <h3 id="children">Children's Privacy</h3>
          <p>Our services are not intended for individuals under the age of 18. We do not knowingly collect personal information from children. If you are a parent or guardian and believe your child has provided us with information, please contact us immediately.</p>

          <hr style="border: none; border-top: 1px solid var(--color-border); margin: var(--spacing-lg) 0;" />

          <h3 id="changes">Changes to This Policy</h3>
          <p>We may update this Privacy Policy from time to time. We will notify you of any changes by posting the new policy on this page and updating the "Last Updated" date. You are advised to review this policy periodically for any changes.</p>

          <hr style="border: none; border-top: 1px solid var(--color-border); margin: var(--spacing-lg) 0;" />

          <h3 id="contact">Contact Us</h3>
          <p>If you have questions about this Privacy Policy or our data practices, please contact us:</p>
          <p style="margin-top: var(--spacing-sm);">
            <strong>Acupuncture in North Georgia</strong><br />
            Ellijay Office: 11 Kiker Street, Ellijay, GA 30540<br />
            Blairsville Office: 563 Gainesville Hwy, Blairsville, GA 30512<br />
            Phone: (410) 961-9033<br />
            Email: [Your email address]<br />
          </p>

          <div style="background-color: var(--color-background); padding: var(--spacing-md); border-radius: var(--radius-md); margin-top: var(--spacing-lg);">
            <p style="font-size: 0.875rem; color: var(--color-text-secondary); margin: 0;">
              <strong>Note:</strong> This privacy policy is a template and should be reviewed by a healthcare attorney to ensure full HIPAA compliance for your specific practice. Last updated February 2026.
            </p>
          </div>
        </article>
      </div>
    </section>

    <!-- Contact Section -->
    <ContactSection />
  </main>
</Layout>
