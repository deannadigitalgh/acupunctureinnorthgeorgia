---
import Layout from '../layouts/Layout.astro';
import ContactSection from '../components/ContactSection.astro';
import MobileCTA from '../components/MobileCTA.astro';
import * as config from '../config/contact.ts';

const pageData = {
  title: `Acupuncture Services | NAET & Facial Rejuvenation - ${config.PRACTICE.name}`,
  description: `Comprehensive acupuncture services in Ellijay and Blairsville, GA. Specializing in Traditional Chinese Medicine, Five-Element Acupuncture, NAET allergy treatment, and Facial Rejuvenation. First visit ${config.PRICING.firstVisit.price} (${config.PRICING.firstVisit.duration}), follow-ups ${config.PRICING.followUp.price} (${config.PRICING.followUp.duration}).`,
  keywords: [
    'acupuncture services Georgia',
    'NAET allergy treatment Ellijay',
    'Facial Rejuvenation acupuncture',
    'Five-Element Acupuncture North Georgia',
    'Traditional Chinese Medicine GA',
    'acupuncture pricing',
    'holistic healing services'
  ],
  canonicalUrl: `${config.DOMAIN}/services`
};

// Logo placement - top of page (no headshot on this page)
const showLogoTop = true;
const showLogoBottom = true;

// Use centralized services config (from contact.ts)
const localServices = [
  ...config.SERVICES,
  {
    title: 'Five-Element Acupuncture',
    icon: '🍃' as const,
    overview: 'Based on the teachings of Professor J.R. Worsley, Five-Element Acupuncture is a holistic approach that addresses the root emotional and physical causes of illness through elemental theory (Wood, Fire, Earth, Metal, Water).',
    benefits: ['Addresses root causes rather than symptoms', 'Emotional healing alongside physical relief', 'Long-lasting results', 'Personalized treatment plans', 'Holistic mind-body-spirit approach'],
    conditionsTreated: [
      { category: 'Emotional Health', items: ['Anxiety and worry', 'Grief and loss', 'Anger management', 'Fear and phobias'] },
      { category: 'Physical Symptoms', items: ['Chronic pain', 'Fatigue', 'Digestive disorders', 'Sleep disturbances'] }
    ]
  }
];

// Treatment process
const treatmentProcess = [
  { step: 1, title: 'Initial Consultation (First Visit)', description: 'Your first visit is 90 minutes and includes a comprehensive health history consultation, physical exam, and your first acupuncture treatment.' },
  { step: 2, title: 'Treatment Planning', description: 'Deanna creates a personalized treatment plan based on your unique needs, symptoms, and healing goals.' },
  { step: 3, title: 'Acupuncture Sessions (Follow-up)', description: '60-minute follow-up treatments where fine needles are inserted at strategic points to restore balance and promote healing.' },
  { step: 4, title: 'Lifestyle Recommendations', description: 'Deanna provides personalized advice on diet, exercise, and self-care practices to enhance treatment results.' }
];

// FAQ preview
const faqs = [
  { question: "What should I expect during my first visit?", answer: "Your first visit is 90 minutes and includes a comprehensive consultation about your health history, a physical exam, and your first acupuncture treatment. This allows Deanna to understand your unique needs and create a personalized treatment plan." },
  { question: "Do the needles hurt?", answer: "The needles are extremely fine—about the size of three hairs. Most patients don't feel them when inserted into non-acupuncture points. When inserted into a point, sensations vary from dull ache to electrical feelings, but it's very momentary (1-2 seconds) and well worth the results." },
  { question: "How many treatments will I need?", answer: "Most people experience changes within 4-10 treatments. A general rule of thumb is one month of weekly treatments for every year you've had a condition. As symptoms improve, treatments are spaced further apart with maintenance sessions once per season." },
  { question: "What should I do before treatment?", answer: "Come rested, wear comfortable clothing, and avoid wearing makeup or fragrances. Eat a light meal beforehand as blood sugar can drop during treatment. Bring any completed forms and write down questions you want to ask." }
];

// Testimonials for services page
const testimonials = [
  { text: "My daughter saw Dee for NAET treatments for several anaphylactic allergies. We just got her blood work back from her allergist and she is negative for most of them!", author: 'J & G', condition: 'NAET Allergy Treatment' },
  { text: "I feel so much better now and can eat and be around items that caused me discomfort before. I have continued to go to Dee for acupuncture treatments 1-2 times a month.", author: 'Jackie A.', condition: 'Food Intolerance Treatment' }
];

// Call-to-action
const cta = {
  primaryText: 'Book Your First Appointment',
  secondaryText: '(410) 961-9033'
};
---

<Layout 
  title={pageData.title} 
  description={pageData.description} 
  keywords={pageData.keywords}
  canonicalUrl={pageData.canonicalUrl}
>
  <!-- Hero Section -->
  <section class="hero">
    <div class="container hero-content">
      <h1>Healing Services - Mind, Body & Soul</h1>
      <p style="font-size: 1.25rem; opacity: 0.95;">Everybody holds the key to their own healing, but sometimes the body needs a little help.</p>
      
      <div class="margin-top-lg">
        <a href="#contact" class="btn btn-primary hero-btn margin-right-sm">{config.PRICING.firstVisit.price} First Visit</a>
        <a href={config.getPhoneLink()} class="btn btn-secondary hero-btn-alt">{config.PHONE.formatted}</a>
      </div>
    </div>
  </section>

  <!-- Logo at top (no headshot on this page) -->
  <section class="section section-light">
    <div class="container text-center margin-bottom-xl">
      <img src="/logo-large.svg" alt="Acupuncture in North Georgia - Deanna Stennett" class="logo-img" />
    </div>
  </section>

  <!-- Overview Section -->
  <section class="section section-light">
    <div class="container">
      <p style="font-size: 1.125rem; line-height: 1.8;">As an experienced acupuncturist, Deanna works with you to restore your balance and find your center. She specializes in acupuncture as well as Facial Rejuvenation and NAET.</p>
      
      <div class="margin-top-xl">
        <h2>Treatment Pricing</h2>
        
        <div class="card-grid margin-top-md">
          <article class="card">
            <h3>First Visit</h3>
            <p style="font-size: 2rem; font-weight: 700; color: var(--color-primary);">{config.PRICING.firstVisit.price}</p>
            <p><strong>{config.PRICING.firstVisit.duration}</strong></p>
            <p style="color: var(--color-text-secondary);">Includes comprehensive consultation, physical exam, and your first acupuncture treatment</p>
          </article>

          <article class="card">
            <h3>Follow-up Treatments</h3>
            <p style="font-size: 2rem; font-weight: 700; color: var(--color-primary);">{config.PRICING.followUp.price}</p>
            <p><strong>{config.PRICING.followUp.duration}</strong></p>
            <p style="color: var(--color-text-secondary);">Follow-up acupuncture treatments tailored to your healing progress</p>
          </article>
        </div>
      </div>
    </div>
  </section>

  <!-- Services Detail Section -->
  <section class="section section-gray">
    <div class="container">
      <h2 class="text-center" style="margin-bottom: var(--spacing-xl);">Our Services</h2>
      
      {localServices.map(service => (
        <article class="margin-bottom-xxl">
          <div class="flex-center gap-sm margin-bottom-md">
            <span style="font-size: 2.5rem;">{service.icon}</span>
            <h3>{service.title}</h3>
          </div>

          <p style="font-size: 1.125rem; line-height: 1.8;">{service.overview}</p>

          <!-- Benefits -->
          {service.benefits && (
            <div class="margin-top-md">
              <h4 style="color: var(--color-secondary);">Benefits:</h4>
              <ul class="list-none flex-wrap gap-sm padding-left-0">
                {service.benefits.map(benefit => (
                  <li class="card-item">✓ {benefit}</li>
                ))}
              </ul>
            </div>
          )}

          <!-- Conditions Treated -->
          {service.conditionsTreated && (
            <div class="margin-top-lg">
              <h4 style="color: var(--color-secondary);">What This Service Can Treat:</h4>
              
              {service.conditionsTreated.map(category => (
                <div class="margin-bottom-md">
                  <p><strong>{category.category}:</strong></p>
                  <ul class="list-none flex-wrap gap-sm padding-left-0">
                    {category.items.map(item => (
                      <li class="card-item-bg">{item}</li>
                    ))}
                  </ul>
                </div>
              ))}
            </div>
          )}
        </article>
      ))}

      <!-- Mission Statement -->
      <blockquote style="font-size: 1.25rem; font-family: var(--font-heading); text-align: center; margin-top: var(--spacing-xl); padding: var(--spacing-lg); background-color: var(--color-background); border-radius: var(--radius-md);">
        "Deanna's mission is to allow her patients to heal and overcome. Through a variety of alternative treatments and approaches, she is able to unlock the potential of self-healing in each patient, sometimes resulting in improvements from the very first session."
      </blockquote>

      <p style="text-align: center; margin-top: var(--spacing-md);">Trust Deanna's hands, trust your ability to heal, and allow yourself to feel better than you ever imagined possible.</p>
    </div>
  </section>

  <!-- Treatment Process Section -->
  <section class="section section-light">
    <div class="container">
      <h2 style="text-align: center; margin-bottom: var(--spacing-lg);">Your Treatment Journey</h2>
      
      <div class="card-grid" style="grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));">
        {treatmentProcess.map(process => (
          <article class="card" style="text-align: center;">
            <div style="font-size: 3rem; font-weight: 700; color: var(--color-primary); margin-bottom: var(--spacing-sm);">{process.step}</div>
            <h4>{process.title}</h4>
            <p>{process.description}</p>
          </article>
        ))}
      </div>

      <!-- General Rule of Thumb -->
      <div style="margin-top: var(--spacing-xl); text-align: center;">
        <h3>A Guideline for Treatment Frequency</h3>
        <p style="font-size: 1.25rem; margin-top: var(--spacing-sm);">"One month of weekly treatments for every year you have had a condition."</p>
      </div>
    </div>
  </section>

  <!-- Testimonials Section -->
  <section class="section section-gray">
    <div class="container">
      <h2 class="text-center" style="margin-bottom: var(--spacing-lg);">Patient Results</h2>
      
      <div class="testimonial-grid" style="grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));">
        {testimonials.map(testimonial => (
          <article class="testimonial-card">
            <p class="testimonial-text">"{testimonial.text}"</p>
            <p class="testimonial-author">{testimonial.author}</p>
            <p style="font-size: 0.875rem; color: var(--color-text-secondary); margin-top: var(--spacing-xs);"><em>{testimonial.condition}</em></p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- FAQ Preview Section -->
  <section class="section section-light">
    <div class="container">
      <h2 class="text-center" style="margin-bottom: var(--spacing-lg);">Frequently Asked Questions</h2>
      
      <div style="max-width: 800px; margin: 0 auto;">
        {faqs.map(faq => (
          <details class="faq-item" style="margin-bottom: var(--spacing-sm);">
            <summary class="faq-question">{faq.question}</summary>
            <p class="faq-answer">{faq.answer}</p>
          </details>
        ))}
      </div>

      <a href="/faq" class="btn btn-secondary" style="display: block; text-align: center; margin-top: var(--spacing-lg);">View All FAQs</a>
    </div>
  </section>

  <!-- Patient Forms Section -->
  <section class="section section-gray">
    <div class="container">
      <h2 class="text-center" style="margin-bottom: var(--spacing-lg);">Patient Intake Forms</h2>
      
      <article class="card" style="max-width: 600px; margin: 0 auto;">
        <p class="text-center" style="font-size: 1.125rem;">Already have an appointment? Below are patient intake forms for your upcoming visit!</p>
        
        <div class="margin-top-lg">
          <a href="#" class="btn btn-primary display-block text-center margin-bottom-sm">Download Patient Intake Form (PDF)</a>
          <a href="#" class="btn btn-secondary display-block text-center">Download Health History Questionnaire (PDF)</a>
        </div>

        <p style="font-size: 0.875rem; color: var(--color-text-secondary); margin-top: var(--spacing-md); text-align: center;">If you have any questions, please do not hesitate to reach out.</p>
      </article>
    </div>
  </section>

  <!-- Logo at bottom (no headshot on this page) -->
  <section class="section section-gray margin-top-xl">
    <div class="container text-center">
      <img src="/logo-large.svg" alt="Acupuncture in North Georgia - Deanna Stennett" class="logo-img" />
    </div>
  </section>

  <!-- Contact Section -->
  <ContactSection />

  <!-- Mobile Sticky CTA -->
  <MobileCTA />

  <!-- SEO Content Block -->
  <article style="display: none;">
    <h2>Acupuncture Services in North Georgia - Comprehensive Holistic Care</h2>
    <p>Deanna Stennett offers a full range of acupuncture services in Ellijay and Blairsville, Georgia. Whether you're seeking relief from chronic pain, allergy treatment through NAET, or natural facial rejuvenation, our holistic approach addresses the root causes of health concerns.</p>

    <h3>Acupuncture Pricing & What to Expect</h3>
    <ul>
      <li><strong>First Visit ($130):</strong> 90-minute comprehensive consultation including health history review, physical exam, and your first acupuncture treatment</li>
      <li><strong>Follow-up Treatments ($90):</strong> 60-minute sessions tailored to your healing progress</li>
    </ul>

    <h3>NAET Allergy Treatment in Northern Georgia</h3>
    <p>NAET (Nambudripad's Allergy Elimination Techniques) provides a safe, non-invasive approach to identifying and eliminating allergies. Many patients in Ellijay, Blairsville, Blue Ridge, and throughout Northern Georgia have achieved remarkable results with NAET for food intolerances, environmental allergies, and chemical sensitivities.</p>

    <h3>Facial Rejuvenation Acupuncture</h3>
    <p>Natural facial rejuvenation through acupuncture offers an effective alternative to cosmetic procedures. By inserting paper-thin needles at strategic points on the face, we increase blood flow, boost collagen production, and remove dead skin cells for a more youthful appearance.</p>

    <h3>Serving Northern Georgia Communities</h3>
    <p>Patients travel from Ellijay, Blairsville, Blue Ridge, Dahlonega, Jasper, Helen, and throughout the North Georgia mountains to receive Deanna's expert acupuncture services. Search "acupuncture near me" and discover why patients trust us with their healing journey.</p>
  </article>
</Layout>
