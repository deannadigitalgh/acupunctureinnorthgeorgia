---
import Layout from '../layouts/Layout.astro';
import ContactSection from '../components/ContactSection.astro';
import * as config from '../config/contact.ts';

const pageData = {
  title: `Acupuncture Testimonials & Patient Reviews | ${config.PRACTICE.name}`,
  description: `Read real patient testimonials about acupuncture treatment with ${config.PRACTICE.founderName} in Ellijay and Blairsville, GA. See results for Bell\\'s Palsy, allergies, chronic pain, and more.`,
  keywords: [
    'acupuncture testimonials',
    'patient reviews acupuncture Georgia',
    'acupuncture success stories',
    'NAET allergy treatment results',
    'Facial Rejuvenation before and after'
  ],
  canonicalUrl: `${config.DOMAIN}/testimonials`
};

// Complete testimonials from old site
const testimonials = [
  {
    id: 1,
    text: `I feel it's the million dollar question I get asked when people find out I go and have Acupuncture done especially those who do not truly know what Acupuncture can really do! In May of this year 2022 I got Bells Palsy. Around June I had a coworker mention to me about Acupuncture and gave me Deanna's card told me to give her a call! A little skeptical like most when they think Acupuncture and needles and of course the fear does it hurt!?! I was tired of taking medicine that just made me feel so bad and to me didn't feel like it was helping all that much, so I thought what could it hurt! It absolutely didn't hurt a thing! It has been my miracle! I could not write enough words and put enough meaning into a testimony to say how wonderful Acupuncture has been for me! Every time someone sees me and is amazed at how well I look and tells me how wonderful my face looks I say it's nothing short of Deanna, Acupuncture, and the Good Lord putting her in my path!! Acupuncture has helped me not only with my Bells Palsy but so many other things that has went on over this year. Each appointment I look forward to because I just always leave so happy and amazed at the progress I see and how well I feel after each appointment! My family members, coworkers, friends, even my doctors all ask me when they see me am I still going to Acupuncture? My response is of course I am!! If I have learned anything from this experience is don't judge a book by it's cover! I am so thankful for this journey and process and I plan to continue my Acupuncture journey for as long as I can! I am forever grateful for Deanna and Acupuncture and the wonderful blessing it has brought into my life!!`,
    author: 'Laura B.',
    condition: "Bell's Palsy Recovery",
    date: '2022',
    featured: true,
    rating: 5
  },
  {
    id: 2,
    text: `Amazing, life changing results! My daughter saw Dee for NAET treatments for several anaphylactic allergies. We just got her blood work back from her allergist and she is negative for most of them, and ready for food challenges for all of them! Not only did we see the concrete results from lab work, we have also seen improvements in her level of confidence, esteem and overall happiness. Thank you Dee!`,
    author: 'J & G',
    condition: 'NAET Allergy Treatment',
    date: '2023',
    featured: true,
    rating: 5
  },
  {
    id: 3,
    text: `I met Deanna after having blood tests done for intolerance's (Elisha Act). When I got the test results back, a friend told about NAET. She told me that now that I knew what I was intolerant to, I needed to see Dee. NAET is a series of 15 acupuncture treatments that are used to treat intolerances. The treatments were a real success. I feel so much better now and can eat and be around items that caused me discomfort before. I have continued to go to Dee for acupuncture treatments 1-2 times a month. Dee is very knowledgeable, a great acupuncturist and a wonderful person.`,
    author: 'Jackie A.',
    condition: 'Food Intolerance Treatment',
    date: '2023',
    featured: true,
    rating: 5
  },
  {
    id: 4,
    text: `I have found acupuncture to be an indispensable part of my overall heath. When I had heart bypass surgery, my healing was very rapid due to the regularity of my acupuncture treatments that help keep the natural healing energy of my body at it's peak. Deanna Slate is a practitioner at the top of her profession. She is knowledgeable in the deepest aspects of the art of acupuncture and a consummate professional due to her many years of practice. She is a compassionate listener and is concerned with the full health and well being of all her patients. I recommend her practice without reservation!`,
    author: 'Joseph B.',
    condition: 'Post-Surgery Recovery',
    date: '2021',
    featured: true,
    rating: 5
  }
];

// Categories for filtering (for future enhancement)
const categories = [
  { name: 'All Testimonials', count: testimonials.length },
  { name: 'Bell\'s Palsy Recovery', count: 1 },
  { name: 'NAET Allergy Treatment', count: 2 },
  { name: 'Chronic Pain Relief', count: 0 },
  { name: 'Post-Surgery Recovery', count: 1 }
];

// Call-to-action (using centralized config)
const cta = {
  primaryText: `Start Your Own Success Story - ${config.PRICING.firstVisit.price} First Visit`,
  secondaryText: config.PHONE.formatted
};
---

<Layout 
  title={pageData.title} 
  description={pageData.description} 
  keywords={pageData.keywords}
  canonicalUrl={pageData.canonicalUrl}
>
  <!-- Hero Section -->
  <section class="hero">
    <div class="container hero-content">
      <h1>Testimonials</h1>
      <p style="font-size: 1.25rem; opacity: 0.95;">Real People, Real Results</p>
      
      <p style="margin-top: var(--spacing-md); max-width: 700px; margin-left: auto; margin-right: auto;">What My Patients Say</p>
      
      <div style="margin-top: var(--spacing-lg);">
        <a href="#contact" class="btn btn-primary" style="background-color: white; color: var(--color-primary);">{cta.primaryText}</a>
        <a href={config.getPhoneLink()} class="btn btn-secondary" style="border-color: white; color: white;">{cta.secondaryText}</a>
      </div>
    </div>
  </section>

  <!-- Logo at top (no headshot on this page) -->
  <section class="section section-light">
    <div class="container" style="text-align: center; margin-bottom: var(--spacing-xl);">
      <img src="/logo-large.svg" alt="Acupuncture in North Georgia - Deanna Stennett" style="max-width: 300px; width: 100%; height: auto;" />
    </div>
  </section>

  <!-- Featured Testimonials -->
  <section class="section section-light">
    <div class="container">
      <h2 style="text-align: center; margin-bottom: var(--spacing-lg);">Featured Success Stories</h2>
      
      <div class="testimonial-grid" style="grid-template-columns: repeat(auto-fit, minmax(350px, 1fr));">
        {testimonials.filter(t => t.featured).map(testimonial => (
          <article class="testimonial-card">
            <!-- Rating Stars -->
            <div style="margin-bottom: var(--spacing-sm); color: #FFD700;">
              {'★'.repeat(testimonial.rating)}{'☆'.repeat(5 - testimonial.rating)}
            </div>

            <p class="testimonial-text" style="font-size: 1.125rem; line-height: 1.8;">{testimonial.text}</p>
            
            <div style="margin-top: var(--spacing-md); padding-top: var(--spacing-sm); border-top: 1px solid var(--color-border);">
              <p class="testimonial-author" style="font-size: 1.25rem;">{testimonial.author}</p>
              <p style="font-size: 0.875rem; color: var(--color-text-secondary); margin-top: var(--spacing-xs);"><em>{testimonial.condition}</em></p>
              <p style="font-size: 0.875rem; color: var(--color-text-secondary);">Published {testimonial.date}</p>
            </div>
          </article>
        ))}
      </div>

      <!-- CTA -->
      <div style="text-align: center; margin-top: var(--spacing-xl);">
        <h3>Create Your Own Success Story</h3>
        <p style="margin-bottom: var(--spacing-md);">Join the many patients who have found healing and relief through acupuncture.</p>
        
        <a href="#contact" class="btn btn-primary">{config.PRICING.firstVisit.price} First Visit - {cta.primaryText}</a>
      </div>
    </div>
  </section>

  <!-- All Testimonials -->
  <section class="section section-gray">
    <div class="container">
      <h2 style="text-align: center; margin-bottom: var(--spacing-lg);">All Patient Reviews</h2>
      
      <p style="text-align: center; max-width: 600px; margin: 0 auto var(--spacing-xl);">Every patient's journey is unique, but the common thread is healing and improved quality of life.</p>

      {testimonials.map(testimonial => (
        <article class="card" style="margin-bottom: var(--spacing-lg); border-left: 4px solid var(--color-primary);">
          <!-- Rating Stars -->
          <div style="margin-bottom: var(--spacing-sm); color: #FFD700;">
            {'★'.repeat(testimonial.rating)}{'☆'.repeat(5 - testimonial.rating)}
          </div>

          <p class="testimonial-text" style="font-size: 1.125rem; line-height: 1.8;">{testimonial.text}</p>
          
          <div style="margin-top: var(--spacing-md); padding-top: var(--spacing-sm); border-top: 1px solid var(--color-border);">
            <p class="testimonial-author">{testimonial.author}</p>
            <p style="font-size: 0.875rem; color: var(--color-text-secondary); margin-top: var(--spacing-xs);"><em>{testimonial.condition}</em></p>
          </div>
        </article>
      ))}

      <!-- Leave a Review CTA -->
      <div style="text-align: center; margin-top: var(--spacing-xl);">
        <h3>Have You Been Treated by Deanna?</h3>
        <p style="margin-bottom: var(--spacing-md);">Share your healing journey and help others discover acupuncture.</p>
        
        <a href="#" class="btn btn-secondary">Leave a Review</a>
      </div>
    </div>
  </section>

  <!-- Results by Category -->
  <section class="section section-light">
    <div class="container">
      <h2 style="text-align: center; margin-bottom: var(--spacing-lg);">Results by Treatment Type</h2>
      
      <div class="card-grid" style="grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));">
        {categories.filter(c => c.count > 0).map(category => (
          <article class="card" style="text-align: center;">
            <h4>{category.name}</h4>
            <p style="font-size: 2rem; font-weight: 700; color: var(--color-primary); margin-top: var(--spacing-sm);">{category.count}+ Reviews</p>
          </article>
        ))}

        <!-- General Acupuncture -->
        <article class="card" style="text-align: center;">
          <h4>General Acupuncture</h4>
          <p style="font-size: 2rem; font-weight: 700; color: var(--color-primary); margin-top: var(--spacing-sm);">100%+ Satisfaction</p>
        </article>
      </div>

      <!-- Treatment Success Stats -->
      <div style="margin-top: var(--spacing-xl); display: grid; gap: var(--spacing-lg); grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));">
        <article class="card" style="text-align: center;">
          <p style="font-size: 3rem; font-weight: 700; color: var(--color-primary); margin-bottom: var(--spacing-xs);">4-10</p>
          <p>Treatments for noticeable results</p>
        </article>

        <article class="card" style="text-align: center;">
          <p style="font-size: 3rem; font-weight: 700; color: var(--color-primary); margin-bottom: var(--spacing-xs);">30+</p>
          <p>Years of experience</p>
        </article>

        <article class="card" style="text-align: center;">
          <p style="font-size: 3rem; font-weight: 700; color: var(--color-primary); margin-bottom: var(--spacing-xs);">100%</p>
          <p>Patient-centered care</p>
        </article>
      </div>
    </div>
  </section>

  <!-- Logo at bottom (no headshot on this page) -->
  <section class="section section-light" style="margin-top: var(--spacing-xl);">
    <div class="container" style="text-align: center;">
      <img src="/logo-large.svg" alt="Acupuncture in North Georgia - Deanna Stennett" style="max-width: 300px; width: 100%; height: auto;" />
    </div>
  </section>

  <!-- Contact Section -->
  <ContactSection />

  <!-- Mobile Sticky CTA (All Pages) -->
  <div class="mobile-cta">
    <div class="container mobile-cta-buttons">
      <a href={config.getPhoneLink()} class="btn btn-primary" style="flex: 1;">Call Now</a>
      <a href="#contact" class="btn btn-secondary" style="flex: 1; border-color: var(--color-primary); color: var(--color-primary);">Book Online</a>
    </div>
  </div>

  <!-- SEO Content Block -->
  <article style="display: none;">
    <h2>Acupuncture Testimonials & Patient Reviews - North Georgia</h2>
    <p>Read real testimonials from patients who have experienced the healing power of acupuncture with Deanna Stennett in Ellijay and Blairsville, Georgia. From Bell's Palsy recovery to NAET allergy treatment success stories, discover why patients travel throughout Northern Georgia for her expert care.</p>

    <h3>Patient Success Stories</h3>
    
    <h4>Bell's Palsy Recovery</h4>
    <p>"It absolutely didn't hurt a thing! It has been my miracle! Acupuncture has helped me not only with my Bell's Palsy but so many other things. I am forever grateful for Deanna and Acupuncture!" - Laura B.</p>

    <h4>NAET Allergy Treatment</h4>
    <p>"Amazing, life changing results! My daughter saw Dee for NAET treatments for several anaphylactic allergies. We just got her blood work back from her allergist and she is negative for most of them!" - J & G.</p>

    <h4>Post-Surgery Recovery</h4>
    <p>"When I had heart bypass surgery, my healing was very rapid due to the regularity of my acupuncture treatments that help keep the natural healing energy of my body at it's peak." - Joseph B.</p>

    <h3>Serving Northern Georgia Communities</h3>
    <p>Patients from Ellijay, Blairsville, Blue Ridge, Dahlonega, Jasper, Helen, and throughout the North Georgia mountains share their acupuncture success stories. Search "acupuncture near me" to find your healing center in Northern Georgia.</p>

    <h3>What Patients Say About Deanna</h3>
    <ul>
      <li>"Dee is very knowledgeable, a great acupuncturist and a wonderful person." - Jackie A.</li>
      <li>"She is knowledgeable in the deepest aspects of the art of acupuncture and a consummate professional due to her many years of practice. She is a compassionate listener." - Joseph B.</li>
    </ul>
  </article>
</Layout>
